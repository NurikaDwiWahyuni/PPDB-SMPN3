# ============================================================
# .env.example — salin file ini menjadi .env dan isi nilainya
# ============================================================

# ── Supabase PostgreSQL ──────────────────────────────────────
# Ambil dari: Supabase > Settings > Database > Connection string
#
# DATABASE_URL → mode "Transaction" (port 6543, pgbouncer=true)
#   Digunakan oleh Prisma Client saat runtime di Vercel (serverless)
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
#
# DIRECT_URL → mode "Session" (port 5432)
#   Digunakan oleh Prisma Migrate / db push (butuh koneksi langsung)
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# ── Supabase Storage ─────────────────────────────────────────
# Ambil dari: Supabase > Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_ID].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="[service_role key — jangan expose ke client!]"

# ── WhatsApp API (Fonnte) ────────────────────────────────────
WA_TOKEN="[token fonnte kamu]"
WA_API_URL="https://api.fonnte.com/send"

# ── Aplikasi ─────────────────────────────────────────────────
# Isi dengan URL Vercel setelah deploy (atau localhost saat dev)
NEXT_PUBLIC_APP_URL="https://ppdb-namamu.vercel.app"

# Secret key untuk signing session cookie
# Generate dengan: openssl rand -base64 32
SESSION_SECRET="ganti-dengan-string-acak-panjang-minimal-32-karakter"
